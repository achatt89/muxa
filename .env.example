# Core service settings
MUXA_SERVICE_NAME=muxa
MUXA_PORT=8081
MUXA_HOST=0.0.0.0
MUXA_JSON_BODY_LIMIT=2mb
MUXA_TOOL_EXECUTION_MODE=server
MUXA_ROUTING_STRATEGY=single
MUXA_PRIMARY_PROVIDER=mock
# Uncomment when enabling fallback
# MUXA_FALLBACK_PROVIDER=openrouter
MUXA_HEADROOM_ENABLED=false
MUXA_HEADROOM_MODE=audit

# Optimization toggles
MUXA_PROMPT_CACHE_ENABLED=true
MUXA_PROMPT_CACHE_TTL_MS=60000
MUXA_PROMPT_CACHE_MAX=200
MUXA_SEMANTIC_CACHE_ENABLED=false
MUXA_SEMANTIC_CACHE_THRESHOLD=0.85
MUXA_MEMORY_ENABLED=true
MUXA_MEMORY_SURPRISE_THRESHOLD=0.6
MUXA_MEMORY_MAX=200
MUXA_MEMORY_TOPK=3

# Provider credentials (examples)
OPENAI_API_KEY=replace-me
ANTHROPIC_API_KEY=replace-me
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com/
AWS_BEDROCK_ACCESS_KEY_ID=replace-me
AWS_BEDROCK_SECRET_ACCESS_KEY=replace-me
OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434
VERTEX_API_KEY=replace-me
DATABRICKS_TOKEN=replace-me

# Policy + telemetry knobs
MUXA_TOOL_SANDBOX_ALLOWLIST=workspace
MUXA_WEB_HOST_ALLOWLIST=localhost,example.com
