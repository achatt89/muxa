## Core service settings
# Friendly name shown in logs/metrics
MUXA_SERVICE_NAME=muxa
# HTTP port/host
MUXA_PORT=8081
MUXA_HOST=0.0.0.0
# Max JSON payload (for tool calls / file edits)
MUXA_JSON_BODY_LIMIT=2mb
# Tool execution mode: server | client | auto
MUXA_TOOL_EXECUTION_MODE=server
# Routing strategy: "single" (always primary) or "hybrid" (use fallback for complex/failing requests)
MUXA_ROUTING_STRATEGY=single
# Primary provider ID (openai, openrouter, ollama, etc.)
MUXA_PRIMARY_PROVIDER=mock
# Optional fallback provider (requires hybrid routing)
# MUXA_FALLBACK_PROVIDER=openrouter
# Headroom compression toggle
MUXA_HEADROOM_ENABLED=false
# Headroom mode: audit (measure only) or optimize (mutate)
MUXA_HEADROOM_MODE=audit

## Optimization toggles
# Enable exact prompt cache
MUXA_PROMPT_CACHE_ENABLED=true
# Prompt cache TTL (ms)
MUXA_PROMPT_CACHE_TTL_MS=60000
# Max prompt cache entries
MUXA_PROMPT_CACHE_MAX=200
# Enable semantic cache (requires embeddings)
MUXA_SEMANTIC_CACHE_ENABLED=false
# Semantic cache similarity threshold (0..1)
MUXA_SEMANTIC_CACHE_THRESHOLD=0.85
# Enable memory extraction/injection
MUXA_MEMORY_ENABLED=true
# Surprise threshold for storing memories
MUXA_MEMORY_SURPRISE_THRESHOLD=0.6
# Max stored memories
MUXA_MEMORY_MAX=200
# Number of memories injected per request
MUXA_MEMORY_TOPK=3

## Provider credentials (examples)
# OpenAI cloud
OPENAI_API_KEY=replace-me
# Optional override settings
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG=org-example
# Force a specific model (used when clients send non-OpenAI names)
# OPENAI_MODEL=gpt-4o-mini
# Map client model names to OpenAI models (comma-separated pairs)
# Example: OPENAI_MODEL_ALIASES=gpt-5.3-codex:gpt-4o-mini,gpt-4.1:gpt-4o
# Additional fallback models to try if requested model is unavailable
# OPENAI_MODEL_FALLBACKS=gpt-5.2-codex,gpt-5.2,gpt-4.1,gpt-4o

## Logging
# Enable verbose OpenAI responses logging (request + SSE payloads)
# MUXA_LOG_RESPONSES=false
# Anthropic cloud
# ANTHROPIC_API_KEY=replace-me
# Azure OpenAI
# AZURE_OPENAI_API_KEY=replace-me
# AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com/
# AWS Bedrock
# AWS_BEDROCK_ACCESS_KEY_ID=replace-me
# AWS_BEDROCK_SECRET_ACCESS_KEY=replace-me
# OpenRouter
# OPENROUTER_API_KEY=replace-me
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Ollama (local or remote host)
# OLLAMA_BASE_URL=http://localhost:11434
# Vertex AI
# VERTEX_API_KEY=replace-me
# Databricks
# DATABRICKS_TOKEN=replace-me

## Policy + telemetry knobs
# Tool sandbox allowlist (comma-separated directories)
MUXA_TOOL_SANDBOX_ALLOWLIST=workspace
# Web fetch allowlist
MUXA_WEB_HOST_ALLOWLIST=localhost,example.com

# MUXA_LOG_RESPONSES=true
