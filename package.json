{
  "name": "@thelogicatelier/muxa",
  "version": "0.1.1",
  "description": "Universal LLM proxy for Cursor, Claude Code, Cline, Antigravity, and OpenAI-compatible tools. Run on any model or provider.",
  "main": "src/index.js",
  "bin": {
    "muxa": "bin/muxa.js"
  },
  "scripts": {
    "start": "dotenv -e .env -- node bin/muxa.js",
    "dev": "nodemon --config nodemon.json",
    "test": "node --test \"test/**/*.test.js\"",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm test",
    "docs:build": "npx honkit@5.1.4 build docs docs-site",
    "docs:serve": "npx honkit@5.1.4 serve docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/achatt89/muxa.git"
  },
  "keywords": [
    "llm",
    "proxy",
    "openai",
    "anthropic",
    "cursor",
    "claude",
    "codex",
    "ai"
  ],
  "author": "Abhijit Chatterjee",
  "bugs": {
    "url": "https://github.com/achatt89/muxa/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://achatt89.github.io/muxa/",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^17.8.1",
    "eslint-plugin-promise": "^6.1.1",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5"
  },
  "license": "MIT",
  "files": [
    "src",
    "bin"
  ]
}